{
  "name": "skynex-pi",
  "version": "0.7.0",
  "description": "Multi-agent coding harness for Pi — triage + 17 skills + 11 sub-agents + 7 extensions. Full medium/substantial-path workflow with HITL gates, TDD enforcement, and adversarial review.",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "skynex",
    "skynex-pi",
    "agents",
    "subagents",
    "workflow",
    "tdd",
    "code-review",
    "ai-coding-agent",
    "agent-harness",
    "multi-agent"
  ],
  "license": "MIT",
  "author": "joeldevz",
  "repository": {
    "type": "git",
    "url": "https://github.com/joeldevz/skynex-pi"
  },
  "homepage": "https://github.com/joeldevz/skynex-pi",
  "bugs": {
    "url": "https://github.com/joeldevz/skynex-pi/issues"
  },
  "files": [
    "extensions/**/*.ts",
    "!extensions/**/*.test.ts",
    "extensions/**/README.md",
    "skills/**/SKILL.md",
    "skills/**/*.md",
    "assets/agents/*.md",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/triage",
      "./extensions/iron-law",
      "./extensions/skill-registry",
      "./extensions/smart-zone",
      "./extensions/neurox-tool",
      "./extensions/production-gate",
      "./extensions/archive",
      "./extensions/skynex-installer"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test extensions/**/*.test.ts",
    "test:triage": "tsx --test extensions/triage/rules.test.ts",
    "doctor": "bash scripts/doctor.sh",
    "start": "bash scripts/start.sh",
    "verify-package": "node scripts/verify-package-files.mjs",
    "prepack": "pnpm test && pnpm typecheck && pnpm verify-package",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm verify-package"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": false
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": false
    }
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.2",
    "typebox": "^1.1.38",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
